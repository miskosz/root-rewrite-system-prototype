### ApplyFirstRule ###

@CallType
type ApplyFirstRule:
    rules_: List<Rule>
    term: Term
@ValueType
type ApplyFirstRuleMatch:
    rules_: List<Rule>
    newterm: Term
@ValueType
type ApplyFirstRuleNoMatch:
    rules_: List<Rule>
    term: Term
@CallType
type ApplyFirstRule2:
    rhs: Term
    rtail: List<Rule>
@CallType
type ApplyFirstRule3:
    rtail: List<Rule>
    binds: List<Bind>
    lhs: Term
@CallType
type ApplyFirstRule4:
    rtail: List<Rule>
    lhs: Term
    rhs: Term
@CallType
type ApplyFirstRule5:
    lhs: Term
    rhs: Term

# ApplyFirstRule(Nil, term) = ApplyFirstRuleNoMatch(Nil, term)
rule Runtime(
    ApplyFirstRule(Nil, term) :: cstack,
    vstack
) ->
    Runtime(
        cstack,
        ApplyFirstRuleNoMatch(Nil, term) :: vstack
    )
# ApplyFirstRule(Rule(lhs, rhs) :: rtail, term) = 
# | out = Match(term, lhs):
# | if let MatchOutTrue(binds, varterm, lhs):
# |     rhs, rhs_copy = CopyTerm(rhs). <-- Potrebujem kopiu rhs
# |     newterm = Substitute(binds, rhs_copy)
# |     return ApplyFirstRuleMatch(
# |         Rule(lhs, rhs) :: rtail,
# |         newterm
# |     )
# | MatchOutFalse(term, lhs) = out
# | match ApplyFirstRule(rtail, term)
# |     case ApplyFirstRuleMatch(rtail, newterm):
# |         return ApplyFirstRuleMatch(Rule(lhs, rhs) ::rtail, newterm)
# |     case ApplyFirstRuleNoMatch(rtail, term):
# |         return ApplyFirstRuleNoMatch(Rule(lhs, rhs) ::rtail, term)
rule Runtime(
    ApplyFirstRule(Rule(lhs, rhs) :: rtail, term) :: cstack,
    vstack
) ->
    Runtime(
        Match(term, lhs) :: ApplyFirstRule2(rhs, rtail) :: cstack,
        vstack
    )
# - True branch
rule Runtime(
    ApplyFirstRule2(rhs, rtail) :: cstack,
    MatchOutTrue(binds, lhs) :: vstack
) ->
    Runtime(
        CopyTerm(rhs) :: ApplyFirstRule3(rtail, binds, lhs) :: cstack,
        vstack
    )
rule Runtime(
    ApplyFirstRule3(rtail, binds, lhs) :: cstack,
    CopyTermOut(rhs, rhs_copy) :: vstack
) ->
    Runtime(
        Substitute(binds, rhs_copy) ::
        ApplyFirstRule4(rtail, lhs, rhs) ::
            cstack,
        vstack
    )
rule Runtime(
    ApplyFirstRule4(rtail, lhs, rhs) :: cstack,
    SubstituteOut(unused_binds, newterm) :: vstack
) ->
    Runtime(
        cstack,
        ApplyFirstRuleMatch(Rule(lhs, rhs) :: rtail, newterm) :: vstack
    )
# - False branch
rule Runtime(
    ApplyFirstRule2(rhs, rtail) :: cstack,
    MatchOutFalse(term, lhs) :: vstack
) ->
    Runtime(
        ApplyFirstRule(rtail, term) :: ApplyFirstRule5(lhs, rhs) :: cstack,
        vstack
    )

rule Runtime(
    ApplyFirstRule5(lhs, rhs) :: cstack,
    ApplyFirstRuleMatch(rtail, newterm) :: vstack
) ->
    Runtime(
        cstack,
        ApplyFirstRuleMatch(Rule(lhs, rhs) :: rtail, newterm) :: vstack
    )

rule Runtime(
    ApplyFirstRule5(lhs, rhs) :: cstack,
    ApplyFirstRuleNoMatch(rtail, term) :: vstack
) ->
    Runtime(
        cstack,
        ApplyFirstRuleNoMatch(Rule(lhs, rhs) :: rtail, term) :: vstack
    )


### RunRRS ###

# RunRRS(Nil, t) = RunRRSOut(t)
rule Runtime(
    RunRRS(Nil, t) :: cstack,
    vstack
) ->
    Runtime(
        cstack,
        RunRRSOut(t) :: vstack
    )
# RunRRS(rules, term) =
# | match ApplyFirstRule(rules, term)
# |     case ApplyFirstRuleMatch(rules, newterm):
# |         return_call RunRRS(rules, newterm)
# |     case ApplyFirstRuleNoMatch(rules, term):
# |         return RunRRSStop(term)
rule Runtime(
    RunRRS(rules_, term) :: cstack,
    vstack
) ->
    Runtime(
        ApplyFirstRule(rules_, term) :: RunRRS2 :: cstack,
        vstack
    )
rule Runtime(
    RunRRS2 :: cstack,
    ApplyFirstRuleMatch(rules_, newterm) :: vstack
) ->
    Runtime(
        RunRRS(rules_, newterm) :: cstack,
        vstack
    )
rule Runtime(
    RunRRS2 :: cstack,
    ApplyFirstRuleNoMatch(rules_, term) :: vstack
) ->
    Runtime(
        cstack,
        RunRRSOut(term) :: vstack
    )

