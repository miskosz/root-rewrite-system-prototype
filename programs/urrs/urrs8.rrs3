# ---------------------

### Match ###

@CallType
type Match:
    term: Term
    varterm: Term
@ValueType
type MatchOutFalse:
    term: Term
    varterm: Term
@ValueType
type MatchOutTrue:
    binds: List<Bind>
    varterm: Term
@CallType
type Match2:
    id: Z8

# Match(t, Var(id)) = MatchOutTrue([Bind(Var(id), t)], Var(id), Var(id))
for 'id in Z8:
rule Runtime(
    Match(t, Var('id)) :: cstack, vstack
) ->
    Runtime(
        cstack,
        MatchOutTrue(Bind(Var('id), t) :: Nil, Var('id)) :: vstack
    )
# Match(
#     Node(id, ch1),
#     Node(id, ch2)
# ) =
# | out = MatchChildren(ch1, ch2)
# | match out:
# |     case MatchChildrenFalse(ch1, ch2):
# |         return MatchOutFalse(...)
# |     case MatchChildrenTrue(binds, ch1, ch2):
# |         return MatchOutTrue(
# |             binds,
# |             Node(id, ch1),
# |             Node(id, ch2)
# |         )
for 'id in Z8:
rule Runtime(
    Match(Node('id, ch1), Node('id, ch2)) :: cstack,
    vstack
) ->
    Runtime(
        MatchChildren(ch1, ch2) :: Match2('id) :: cstack,
        vstack
    )
for 'id in Z8:
rule Runtime(
    Match2('id) :: cstack,
    MatchChildrenOutFalse(ch1, ch2) :: vstack
) ->
    Runtime(
        cstack,
        MatchOutFalse(Node('id, ch1), Node('id, ch2)) :: vstack
    )
for 'id in Z8:
rule Runtime(
    Match2('id) :: cstack,
    MatchChildrenOutTrue(binds, ch2) :: vstack
) ->
    Runtime(
        cstack,
        MatchOutTrue(binds, Node('id, ch2)) :: vstack
    )
# Match(_x, _y) = MatchOut(Match(_x, _y))
rule Runtime(
    Match(x, y) :: cstack, vstack
) ->
    Runtime(
        cstack,
        MatchOutFalse(x, y) :: vstack
    )


### MatchChildren ###

@CallType
type MatchChildren:
    ch1: List<Term>
    ch2: List<Term>
@ValueType
type MatchChildrenOutFalse:
    ch1: List<Term>
    ch2: List<Term>
@ValueType
type MatchChildrenOutTrue:
    binds: List<Bind>
    ch2: List<Term>
@CallType
type MatchChildren2:
    tail1: List<Term>
    tail2: List<Term>
@CallType
type MatchChildren3:
    head_binds: List<Bind>
    h2: Term
@CallType
type MatchChildren4:
    h2: Term
    tail2: List<Term>
@CallType
type MatchChildren5:
    h2: Term
    tail1: List<Term>
    tail2: List<Term>
@CallType
type MatchChildren6:
    head_binds: List<Bind>
    tail1: List<Term>
    tail2: List<Term>

# MatchChildren(Nil, Nil) = MatchChildrenOutTrue(Nil, Nil)
rule Runtime(
    MatchChildren(Nil, Nil) :: cstack, vstack
) ->
    Runtime(cstack, MatchChildrenOutTrue(Nil, Nil) :: vstack)
# MatchChildren(h1 :: tail1, h2 :: tail2) =
# | out = Match(h1, h2)
# | if let MatchOutFalse(h1, h2) = out:
# |     return MatchChildrenOutFalse(h1 :: tail1, h2 :: tail2)
# | MatchOutTrue(head_binds, h1, h2) = out
# | out2 = MatchChildren(tail1, tail2)
# | if let MatchChildrenOutFalse(tail1, tail2) = out:
# |     h1 = Substitute(head_binds, h1)
# |     return MatchChildrenOutFalse(h1 :: tail1, h2 :: tail2)
# | MatchChildrenOutTrue(tail_binds, tail1, tail2) = out2
# | binds = ListMerge(head_binds, tail_binds)
# | return MatchChildrenOutTrue(binds, h1 :: tail1, h2 :: tail2)
rule Runtime(
    MatchChildren(h1 :: tail1, h2 :: tail2) :: cstack,
    vstack
) ->
    Runtime(
        Match(h1, h2) :: MatchChildren2(tail1, tail2) :: cstack,
        vstack
    )
rule Runtime(
    MatchChildren2(tail1, tail2) :: cstack,
    MatchOutFalse(h1, h2) :: vstack
) ->
    Runtime(
        cstack,
        MatchChildrenOutFalse(h1 :: tail1, h2 :: tail2) :: vstack
    )
rule Runtime(
    MatchChildren2(tail1, tail2) :: cstack,
    MatchOutTrue(head_binds, h2) :: vstack
) ->
    Runtime(
        MatchChildren(tail1, tail2) ::
        MatchChildren3(head_binds, h2) ::
            cstack,
        vstack
    )
# - False branch
rule Runtime(
    MatchChildren3(head_binds, h2) :: cstack,
    MatchChildrenOutFalse(tail1, tail2) :: vstack
) ->
    Runtime(
        CopyTerm(h2) ::
        MatchChildren6(head_binds, tail1, tail2) :: cstack,
        vstack
    )
rule Runtime(
    MatchChildren6(head_binds, tail1, tail2) :: cstack,
    CopyTermOut(h1, h2) :: vstack
) ->
    Runtime(
        Substitute(head_binds, h1) ::
        MatchChildren5(h2, tail1, tail2) ::
            cstack,
        vstack
    )
rule Runtime(
    MatchChildren5(h2, tail1, tail2) :: cstack,
    SubstituteOut(unused_binds, h1) :: vstack
) ->
    Runtime(
        cstack,
        MatchChildrenOutFalse(h1 :: tail1, h2 :: tail2) :: vstack
    )
# - True branch    
rule Runtime(
    MatchChildren3(head_binds, h2) :: cstack,
    MatchChildrenOutTrue(tail_binds, tail2) :: vstack
) ->
    Runtime(
        ListMerge(head_binds, tail_binds) ::
        MatchChildren4(h2, tail2) ::
            cstack,
        vstack
    )
rule Runtime(
    MatchChildren4(h2, tail2) :: cstack,
    ListMergeOut(binds) :: vstack
) ->
    Runtime(
        cstack,
        MatchChildrenOutTrue(binds, h2 :: tail2) :: vstack
    )


### Substitute ###

@CallType
type Substitute:
    binds: List<Bind>
    varterm: Term
@ValueType
type SubstituteOut:
    unused_binds: List<Bind>
    varterm: Term
@CallType
const Substitute2
@CallType
type Substitute3:
    id: Z8
    chtail: List<Term>
@CallType
type Substitute4:
    id: Z8
    ch1: Term

# Substitute
# Substitute(binds, Var(id)) = 
# | out = FindBind(binds, Var(id))
# | if let FindBindOutMatch(binds, Var(id), match):
# |     return SubstituteOut(binds, match)
# | else:
# |     return SubstituteOut(binds, Var(id))
rule Runtime(
    Substitute(binds, Var(id)) :: cstack,
    vstack
) ->
    Runtime(
        FindBind(binds, Var(id)) :: Substitute2 :: cstack,
        vstack
    )
rule Runtime(
    Substitute2 :: cstack,
    FindBindOutNoMatch(binds, Var(id)) :: vstack
) ->
    Runtime(
        cstack,
        SubstituteOut(binds, Var(id)) :: vstack
    )
rule Runtime(
    Substitute2 :: cstack,
    FindBindOutMatch(binds, Var(id), match) :: vstack
) ->
    Runtime(
        cstack,
        SubstituteOut(binds, match) :: vstack
    )
# Substitute(binds, Node(id, Nil)) = SubstituteOut(binds, Node(id, Nil))
rule Runtime(
    L(Substitute(binds, Node(id, Nil)), cstack),
    vstack
) ->
    Runtime(
        cstack,
        L(SubstituteOut(binds, Node(id, Nil)), vstack)
    )
# Substitute(binds, Node(id, ch1 :: chtail)) =
# | binds, sub_ch1 = Substitute(binds, ch1)
# | # Slight hack, we could also have SubstistuteMany that takes List<Term>
# | binds, Node(I0, sub_chtail) = Substitute(binds, Node(I0, chtail))
# | return SubstituteOut(binds, Node(id, sub_ch1, sub_chtail))
rule Runtime(
    Substitute(binds, Node(id, ch1 :: chtail)) :: cstack,
    vstack
) ->
    Runtime(
        Substitute(binds, ch1) :: Substitute3(id, chtail) :: cstack,
        vstack
    )
rule Runtime(
    Substitute3(id, chtail) :: cstack,
    SubstituteOut(binds, ch1) :: vstack
) ->
    Runtime(
        Substitute(binds, Node(I0, chtail)) ::
        Substitute4(id, ch1) ::
            cstack,
        vstack
    )
rule Runtime(
    Substitute4(id, ch1) :: cstack,
    SubstituteOut(binds, Node(I0, chtail)) :: vstack
) ->
    Runtime(
        cstack,
        SubstituteOut(binds, Node(id, ch1 :: chtail)) :: vstack
    )


### FindBind ###

@CallType
type FindBind:
    binds: List<Bind>
    var: Var
@ValueType
type FindBindOutNoMatch:
    binds: List<Bind>
    var: Var
@ValueType
type FindBindOutMatch:
    binds: List<Bind>
    var: Var
    match: Bind
@CallType
type FindBind2:
    bind1: Bind

# FindBind(Nil, var) = FindBindNoMatch(Nil, var)
rule Runtime(
    FindBind(Nil, var) :: cstack, vstack
) ->
    Runtime(
        cstack, FindBindOutNoMatch(Nil, var) :: vstack
    )
# FindBind(Bind(Var(id), term) :: btail, Var(id)) =
# |     return FindBindOutMatch(btail, var, term)
for 'id in Z8:
rule Runtime(
    FindBind(Bind(Var('id), term) :: btail, Var('id)) :: cstack,
    vstack
) ->
    Runtime(
        cstack,
        FindBindOutMatch(btail, Var('id), term) :: vstack
    )
# FindBind(bind1 :: btail, Var(id)) =
# | match FindBind(btail, Var(id)):
# |     case FindBindOutNoMatch(btail, Var(id)):
# |         return FindBindOutNoMatch(bind1 :: btail, Var(id))
# |     case FindBindOutMatch(btail, Var(id), match):
# |         return FindBindOutMatch(bind1 :: btail, Var(id), match)
rule Runtime(
    FindBind(bind1 :: btail, Var(id)) :: cstack,
    vstack
) ->
    Runtime(
        FindBind(btail, Var(id)) :: FindBind2(bind1) :: cstack,
        vstack
    )
rule Runtime(
    FindBind2(bind1) :: cstack,
    FindBindOutNoMatch(btail, Var(id)) :: vstack
) ->
    Runtime(
        cstack,
        FindBindOutNoMatch(bind1 :: btail, Var(id)) :: vstack
    )
rule Runtime(
    FindBind2(bind1) :: cstack,
    FindBindOutMatch(btail, Var(id), match) :: vstack
) ->
    Runtime(
        cstack,
        FindBindOutMatch(bind1 :: btail, Var(id), match) :: vstack
    )

