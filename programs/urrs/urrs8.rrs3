# 8-id 8-var URRS implementation

const I0
const I1
const I2
const I3
const I4
const I5
const I6
const I7
alias Z8: I0 | I1 | I2 | I3 | I4 | I5 | I6 | I7

type Var:
    Z8

type Node:
    id: Z8
    children: List<Term>
alias Term: Node | Var

const Nil
type L<'t>:
    head: 't
    tail: List<'t>
alias List<'t>: L<'t> | Nil

type Runtime:
    call_stack: List<CallType>
    value_stack: List<ValueType>
open alias CallType
open alias ValueType

# ---

type Bind:
    var: Var
    term: Term

type Rule:
    lhs: Term
    rhs: Term

@CallType
type RunRRS:
    rules_: List<Rule>
    input_: Term
@ValueType
type RunRRSOut:
    term: Term
@CallType
const RunRRS2

# ---

### ListMerge ###

# TODO: Open alias registration of generics does not work properly!!!
# type ListMerge<'t>:
#     List<'t>
#     List<'t>
# type ListMergeOut<'t>:
#     List<'t>

@CallType
type ListMerge:
    List<Bind>
    List<Bind>
@ValueType
type ListMergeOut:
    List<Bind>

# ListMerge(Nil, l2) = ListMergeOut(l2)
rule Runtime(
    ListMerge(Nil, l2) :: cstack, vstack
) ->
    Runtime(
        cstack, ListMergeOut(l2) :: vstack
    )
# ListMerge(head :: tail, l2) = ListMerge(tail, head :: l2)
rule Runtime(
    ListMerge(head :: tail, l2) :: cstack, vstack
) ->
    Runtime(
        ListMerge(tail, head :: l2) :: cstack, vstack
    )


### CopyTerm ###

@CallType
type CopyTerm:
    t: Term
@ValueType
type CopyTermOut:
    t1: Term
    t2: Term
@CallType
type CopyTerm2:
    id: Z8

# CopyTerm(Var(id)) = CopyTermOut(Var(id), Var(id))
for 'id in Z8:
rule Runtime(
    CopyTerm(Var('id)) :: cstack,
    vstack
) ->
    Runtime(
        cstack,
        CopyTermOut(Var('id), Var('id)) :: vstack
    )
# CopyTerm(Node(id, ch)) = 
# | ch1, ch2 = CopyTerms(ch)
# | return CopyTermOut(Node(id, ch1), Node(id, ch2))
for 'id in Z8:
rule Runtime(
    CopyTerm(Node('id, ch)) :: cstack,
    vstack
) ->
    Runtime(
        CopyTerms(ch) :: CopyTerm2('id) :: cstack,
        vstack
    )
for 'id in Z8:
rule Runtime(
    CopyTerm2('id) :: cstack,
    CopyTermsOut(ch1, ch2) :: vstack
) ->
    Runtime(
        cstack,
        CopyTermOut(Node('id, ch1), Node('id, ch2)) :: vstack
    )

### CopyTerms ###

@CallType
type CopyTerms:
    terms: List<Term>
@ValueType
type CopyTermsOut:
    terms1: List<Term>
    terms2: List<Term>
@CallType
const CopyTerms2

# CopyTerms(Nil) = CopyTermsOut(Nil, Nil)
rule Runtime(
    CopyTerms(Nil) :: cstack,
    vstack
) ->
    Runtime(
        cstack,
        CopyTermsOut(Nil, Nil) :: vstack
    )
# CopyTerms(t :: ttail) = |
# | t1, t2 = CopyTerm(t)
# | ttail1, ttail2 = CopyTerms(ttail)
# | return CopyTerms(t1 :: ttail1, t2 :: ttail2)
rule Runtime(
    CopyTerms(t :: ttail) :: cstack,
    vstack
) ->
    Runtime(
        CopyTerm(t) :: CopyTerms(ttail) :: CopyTerms2 :: cstack,
        vstack
    )
rule Runtime(
    CopyTerms2 :: cstack,
    CopyTermsOut(ttail1, ttail2) :: CopyTermOut(t1, t2) :: vstack
) ->
    Runtime(
        cstack,
        CopyTermsOut(t1 :: ttail1, t2 :: ttail2) :: vstack
    )

